# Copy to .env (or set these in your host's dashboard).

# Postgres connection string (from Neon / Supabase / Render Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Long random string used to sign login tokens. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Your Anthropic API key — powers the coach/insight/food-AI for ALL users.
ANTHROPIC_API_KEY=sk-ant-...

# Optional
PORT=8080
AI_HOURLY_LIMIT=60          # max AI calls per IP per hour
# PGSSL=disable             # set only if your DB does NOT use SSL (most managed DBs do)
# CLIENT_DIR=./public       # where the static client lives (defaults to ../public)
